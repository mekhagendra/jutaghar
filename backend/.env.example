MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/collection?appName=mern
PORT=8000
NODE_ENV=development

CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT Configuration
JWT_SECRET=your_secure_jwt_secret_key_change_this_in_production
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=90d

# Cloudinary Image Uploads
# Set CLOUDINARY_URL or provide the three values below.
CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
# CLOUDINARY_CLOUD_NAME=<cloud_name>
# CLOUDINARY_API_KEY=<api_key>
# CLOUDINARY_API_SECRET=<api_secret>
# Optional folder prefix used for all uploaded images
CLOUDINARY_FOLDER=jutaghar
MAX_FILE_SIZE=5242880

# Application
APP_NAME=JutaGhar
APP_VERSION=1.0.0

# Payment Gateway Configuration
# eSewa Configuration (Nepal)
ESEWA_MERCHANT_CODE=EPAYTEST
ESEWA_SECRET_KEY=secret_key_for_esewa
ESEWA_PAYMENT_URL=https://rc-epay.esewa.com.np/api/ep

# Khalti Configuration (Nepal)
KHALTI_SECRET_KEY=your_khalti_secret_key_here
KHALTI_PUBLIC_KEY=your_khalti_public_key_here
KHALTI_GATEWAY_URL=https://a.khalti.com/api/v2

# SMTP / Email
SMTP_USER=your_smtp_user@example.com
SMTP_PASSWORD=your_smtp_password

# OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Admin seed script (used by createAdmin.js)
ADMIN_EMAIL=admin@jutaghar.com
ADMIN_PASSWORD=

# Payment webhook signing secrets (Khalti / generic)
KHALTI_WEBHOOK_SECRET=
PAYMENT_WEBHOOK_SECRET=

# Operational toggles
LOG_LEVEL=info
# Set to 'true' to disable the scheduled payment reconciliation cron
DISABLE_PAYMENT_RECONCILE_CRON=false
